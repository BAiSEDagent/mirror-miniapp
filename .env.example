# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://mirror.baised.xyz

# ─── Coinbase Developer Platform ──────────────────────────────────────────────
# Get from: https://portal.cdp.coinbase.com/products/onchainkit
NEXT_PUBLIC_CDP_CLIENT_KEY=your_cdp_client_key

# Base Paymaster (gasless transactions)
# Get from: https://docs.cdp.coinbase.com/paymaster/
NEXT_PUBLIC_PAYMASTER_URL=https://api.developer.coinbase.com/rpc/v1/base/your_paymaster_key

# ─── Farcaster Manifest (run: npx create-onchain --manifest) ──────────────────
FARCASTER_HEADER=your_jfs_header_base64
FARCASTER_PAYLOAD=your_jfs_payload_base64
FARCASTER_SIGNATURE=your_jfs_signature_base64

# ─── Neynar (Farcaster Hub / FID resolution) ──────────────────────────────────
# Get from: https://dev.neynar.com/
NEYNAR_API_KEY=your_neynar_api_key
NEYNAR_HUB_URL=https://hub-api.neynar.com

# ─── Alchemy (wallet activity / trade history) ────────────────────────────────
# Get from: https://dashboard.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_api_key

# ─── x402 ─────────────────────────────────────────────────────────────────────
# Facilitator URL for USDC payment verification
X402_FACILITATOR_URL=https://x402.org/facilitate
MIRROR_TREASURY_ADDRESS=0xYourTreasuryWalletAddress

# ─── RPC ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
